# ============================================================
# LendStack — environment template. Copy to .env and fill in.
# NOTHING here is hardcoded in the applications.
# ============================================================

# --- Database ---
DB_NAME=lendstack
DB_USER=lendstack
DB_PASSWORD=change-me-strong-password

# --- Backend secrets (REQUIRED) ---
# JWT signing key: any random string, minimum 32 characters
JWT_SECRET=change-me-to-a-random-string-of-32+chars
# PII encryption key (BVN/NIN/account numbers at rest): base64 of 32 random bytes
#   generate: openssl rand -base64 32
PII_ENCRYPTION_KEY=

# --- Paystack (test keys from https://dashboard.paystack.com/#/settings/developers) ---
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
# Where Paystack redirects the borrower's browser after checkout
PAYSTACK_CALLBACK_URL=http://localhost:3000/borrower/repayments/callback

# --- URLs ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- Profile: dev seeds demo users/lenders; use "default" for none ---
SPRING_PROFILES_ACTIVE=dev

# --- CBN / lending parameters (seed values only; after first boot ADMIN
#     edits these live via /api/v1/admin/config — no redeploy needed) ---
CBN_INTEREST_RATE_CAP_ANNUAL=30.00
CBN_MIN_TENURE_MONTHS=1
CBN_MAX_TENURE_MONTHS=24
DEFAULT_INTEREST_RATE_ANNUAL=24.00
PENALTY_RATE_DAILY_PERCENT=0.25
GRACE_PERIOD_DAYS=3
COLLATERAL_THRESHOLD_NGN=2000000
GUARANTOR_TIER1_MAX_NGN=500000
GUARANTOR_TIER2_MAX_NGN=2000000
GUARANTOR_EXPIRY_HOURS=72
MIN_LOAN_AMOUNT_NGN=50000
MAX_LOAN_AMOUNT_NGN=10000000
DELINQUENT_DAYS_TO_DEFAULT=90
